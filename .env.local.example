# Chat backend — streams AI SDK v4 UI messages
# Expected to speak the AI SDK data stream protocol.
VITE_CHAT_API_URL=https://api.lux.cloud/v1/chat/stream

# Public API base for chat persistence + billing
VITE_API_BASE=https://api.lux.cloud

# Default model ID surfaced in the UI
VITE_DEFAULT_MODEL=zen4-mini

# Auth — lux.id + hanzo.id OAuth (client-side PKCE)
VITE_LUX_IAM_URL=https://lux.id
VITE_LUX_IAM_CLIENT_ID=lux-chat-client-id
VITE_HANZO_IAM_URL=https://hanzo.id
VITE_HANZO_IAM_CLIENT_ID=hanzo-chat-client-id

# Billing
VITE_FREE_DAILY_QUERIES=10
